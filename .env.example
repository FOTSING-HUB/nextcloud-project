# ==============================================================
# NEXTCLOUD - VARIABLES D'ENVIRONNEMENT
# Copier ce fichier : cp .env.example .env
# Puis remplir toutes les valeurs CHANGE_ME
# IMPORTANT : Ne jamais commiter le fichier .env dans Git !
# ==============================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Nextcloud admin ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_admin_password_here
NEXTCLOUD_TRUSTED_DOMAINS=localhost 192.168.1.100

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# --- AWS (pour ECR et S3) ---
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=eu-west-1
AWS_S3_BUCKET=nextcloud-backup-CHANGE_ME
ECR_REGISTRY=123456789.dkr.ecr.eu-west-1.amazonaws.com
ECR_REPOSITORY=nextcloud-custom

# --- Domaine et HTTPS ---
DOMAIN=localhost
LETSENCRYPT_EMAIL=admin@yourdomain.com

# --- PHP / Nextcloud ---
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_LIMIT=10G
